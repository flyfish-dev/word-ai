{
  "name": "@flyfish-dev/word-ai",
  "version": "0.8.6",
  "description": "Structure-preserving Word DOCX editing MCP server and Office.js bridge for AI agents",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/flyfish-dev/word-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/word-ai.git"
  },
  "bugs": {
    "url": "https://github.com/flyfish-dev/word-ai/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "word",
    "docx",
    "office",
    "office-js",
    "ooxml",
    "openxml",
    "codex",
    "claude"
  ],
  "bin": {
    "word-ai": "bin/word-ai.js",
    "word-ai-mcp": "bin/word-ai-mcp.js",
    "word-ai-http": "bin/word-ai-http.js"
  },
  "scripts": {
    "native:publish": "python3 scripts/publish_native_backends.py",
    "native:publish:all": "python3 scripts/publish_native_backends.py --all --clean",
    "native:verify": "python3 scripts/verify_native_backends.py",
    "native:verify:all": "python3 scripts/verify_native_backends.py --require-all",
    "mcpb:build": "python3 scripts/build_mcpb.py",
    "standalone:build": "python3 scripts/build_standalone.py --build-native",
    "standalone:package": "python3 scripts/package_quickstart.py",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "files": [
    "bin/",
    "word_ai_mcp/*.py",
    "schemas/",
    "skills/",
    "codex-skill/",
    "scripts/install_agent_skills.py",
    "scripts/validate_word_ai_skill.py",
    "scripts/publish_native_backends.py",
    "scripts/verify_native_backends.py",
    "scripts/package_native_assets.py",
    "scripts/build_standalone.py",
    "scripts/package_quickstart.py",
    "scripts/publish_dotnet.sh",
    "scripts/publish_dotnet.ps1",
    "pyproject.toml",
    "requirements.txt",
    "requirements-standalone.txt",
    "README.md",
    "README.zh-CN.md",
    "docs/*.md",
    "CONTRIBUTING.md",
    "CONTRIBUTING.zh-CN.md",
    "SECURITY.md",
    "SECURITY.zh-CN.md",
    "LICENSE",
    "AGENTS.md",
    "server.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
